#!/usr/bin/env bash
# icode -- run Claude Code through claude-code-router (CCR), routing
# requests to the active provider configured in ~/.config/icode/config.json.
#
# Both openai and anthropic provider types route through CCR. The vendored
# Anthropic transformer has been patched to read the bearer token from
# ANTHROPIC_TOKEN_FILE per request, so token rotation is invisible to
# in-flight sessions for both flavors.
#
# Flags consumed here (NOT forwarded to claude-code):
#   --provider NAME   switch the active provider for this and subsequent runs
#   --list            list configured providers and exit
#   --safe            keep claude-code's permission prompts (default: skip)

set -euo pipefail

NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
CCR_CFG="$HOME/.claude-code-router/config.json"
REFRESH_BIN="$HOME/.local/bin/code-router-refresh-token"

PROVIDER=""
SAFE_MODE=0
FORWARD_ARGS=()
while (( $# )); do
  case "$1" in
    --provider) PROVIDER="${2:-}"; shift 2 ;;
    --provider=*) PROVIDER="${1#*=}"; shift ;;
    --list) exec "${REFRESH_BIN}" --list ;;
    --safe) SAFE_MODE=1; shift ;;
    *) FORWARD_ARGS+=("$1"); shift ;;
  esac
done

# If config doesn't exist (fresh install) OR the user is switching providers,
# run the refresh script first.
if [[ ! -r "$CCR_CFG" || -n "$PROVIDER" ]]; then
  if [[ -x "$REFRESH_BIN" ]]; then
    if [[ -n "$PROVIDER" ]]; then
      "$REFRESH_BIN" --provider "$PROVIDER"
    else
      "$REFRESH_BIN"
    fi
  else
    echo "icode: $REFRESH_BIN not found -- run 'make install'" >&2
    exit 1
  fi
fi

if [[ -s "$NVM_DIR/nvm.sh" ]]; then
  # nvm refuses to load when the PREFIX env var is set (e.g. when invoked
  # from a worker process that has its own PREFIX). Strip it.
  unset PREFIX
  # shellcheck disable=SC1091
  . "$NVM_DIR/nvm.sh"
  nvm use --delete-prefix --silent 22 >/dev/null
fi

# Trust the corporate CA bundle the timer installed at fetch time.
CA_FILE="$HOME/.local/share/ca-certs/code-router-ca.pem"
if [[ -r "$CA_FILE" ]]; then
  export NODE_EXTRA_CA_CERTS="$CA_FILE"
fi

# Tell the patched CCR Anthropic transformer where to read the live bearer
# token from. The daemon inherits this when spawned by `ccr code`.
export ANTHROPIC_TOKEN_FILE="$HOME/.claude-code-router/token.txt"

# Bump the Read tool's per-call token cap from the default 25k to 128k so
# large MCP tool results (e.g. read_workpaper dumping a multi-sheet xlsx)
# don't blow up the model's ingestion path. Caller can override.
export CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS="${CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS:-128000}"

SKIP_PERMS=()
if (( ! SAFE_MODE )); then
  SKIP_PERMS=(--dangerously-skip-permissions)
fi

# A provider switch changed Router.default, but a running CCR daemon caches
# its config in memory -- restart it so the new routing takes effect.
# Plain token rotation doesn't need a restart; that's handled per-request
# by the inject-token plugin / patched Anthropic transformer.
if [[ -n "$PROVIDER" ]]; then
  ccr restart >/dev/null 2>&1 || true
fi

exec ccr code ${SKIP_PERMS[@]+"${SKIP_PERMS[@]}"} ${FORWARD_ARGS[@]+"${FORWARD_ARGS[@]}"}
