#!/usr/bin/env python3
"""icode -- run Claude Code through the local code-router daemon, routing
this session to a chosen provider.

The single daemon serves any number of providers concurrently; per-session
selection happens via the --model flag we pass through to claude-code, which
the daemon parses as "provider,model" and dispatches per request.

This launcher does three things:

  1. Resolve which provider this session uses
       --provider NAME flag, else default.toml, else error.

  2. Prime that provider's OAuth token by calling the daemon's localhost-only
     admin endpoint:
        POST http://127.0.0.1:3456/__admin/prime  {"provider": NAME}
     The daemon (running as user code-router in system mode, or as the
     invoking user in per-user mode) reads the icode config, mints the
     token, and writes tokens/<NAME>.txt. icode never touches credentials.

  3. Look up the configured model name (GET /__admin/model?provider=NAME)
     and exec `claude --model NAME,<model> ...` with the env vars that
     point claude-code at the local daemon.

Install modes (auto-detected from $0's directory):
  /usr/local/bin/icode  -> system mode (daemon started by systemd at boot)
  anywhere else         -> per-user mode (daemon spawned lazily by `ccr start`)

Flags consumed here (NOT forwarded to claude-code):
  --provider NAME   route this session to NAME (NOT a global switch)
  --list            list configured providers and exit
  --safe            keep claude-code's permission prompts (default: skip)
"""

import argparse
import json
import os
import shutil
import subprocess
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path

# ---- discover paths -------------------------------------------------------

HOME = Path.home()
SCRIPT_DIR = Path(__file__).resolve().parent
SYSTEM_MODE = str(SCRIPT_DIR) == "/usr/local/bin"

USER_CFG = HOME / ".config" / "icode" / "config.json"
SYSTEM_CFG = Path("/etc/icode/config.json")
ICODE_CFG = Path(os.environ.get("ICODE_CFG") or (USER_CFG if USER_CFG.is_file() else SYSTEM_CFG))
ICODE_CFG_DIR = ICODE_CFG.parent
DEFAULT_FILE = ICODE_CFG_DIR / "default.toml"

DAEMON_BASE = os.environ.get("CODE_ROUTER_DAEMON_BASE", "http://127.0.0.1:3456")

# ---- helpers --------------------------------------------------------------


def die(msg: str, code: int = 1) -> None:
    print(f"icode: {msg}", file=sys.stderr)
    sys.exit(code)


def read_default_provider() -> str | None:
    """Hand-parse default.toml -- one line: provider = "name"."""
    if not DEFAULT_FILE.is_file():
        return None
    try:
        text = DEFAULT_FILE.read_text()
    except OSError as e:
        die(f"{DEFAULT_FILE}: {e}")
    import re
    m = re.search(r'^\s*provider\s*=\s*"([^"]+)"', text, re.MULTILINE)
    if not m:
        die(f'{DEFAULT_FILE}: expected a line `provider = "NAME"`')
    return m.group(1)


def daemon_get(path: str, timeout: float = 10.0) -> tuple[int, str]:
    req = urllib.request.Request(DAEMON_BASE + path, method="GET")
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return resp.status, resp.read().decode("utf-8")
    except urllib.error.HTTPError as e:
        return e.code, e.read().decode("utf-8", errors="replace")


def daemon_post(path: str, body: dict, timeout: float = 30.0) -> tuple[int, str]:
    data = json.dumps(body).encode("utf-8")
    req = urllib.request.Request(
        DAEMON_BASE + path,
        method="POST",
        headers={"Content-Type": "application/json"},
        data=data,
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return resp.status, resp.read().decode("utf-8")
    except urllib.error.HTTPError as e:
        return e.code, e.read().decode("utf-8", errors="replace")


def daemon_alive() -> bool:
    try:
        # /health is the unauthenticated upstream endpoint; works regardless
        # of how Providers[] is configured.
        with urllib.request.urlopen(DAEMON_BASE + "/health", timeout=2) as resp:
            return resp.status == 200
    except (urllib.error.URLError, urllib.error.HTTPError, ConnectionError, OSError):
        return False


def ensure_daemon_running() -> None:
    """Per-user mode only: start the daemon if it isn't already running.
    System mode is handled by systemd at boot; this function is a no-op
    there."""
    if SYSTEM_MODE:
        if not daemon_alive():
            die(
                "daemon not reachable at "
                + DAEMON_BASE
                + " (systemctl status code-router.service)"
            )
        return

    if daemon_alive():
        return

    ccr = shutil.which("ccr")
    if not ccr:
        die("ccr not on PATH -- make sure Node 20+ is installed and `npm i -g` works")

    # Set the env the daemon will inherit. Per-user systemd timer's
    # code-router.service sets these for the timer-driven refresh; we set the
    # same ones here so the on-demand daemon spawn picks them up too.
    env = os.environ.copy()
    ca = HOME / ".local" / "share" / "ca-certs" / "code-router-ca.pem"
    if ca.is_file():
        env.setdefault("NODE_EXTRA_CA_CERTS", str(ca))
    env.setdefault(
        "ANTHROPIC_TOKEN_DIR", str(HOME / ".claude-code-router" / "tokens")
    )
    env.setdefault("ICODE_CFG", str(ICODE_CFG))
    env.setdefault(
        "CODE_ROUTER_DIR", str(HOME / ".claude-code-router")
    )

    # Detach so we don't keep a handle on the daemon process. `ccr start`
    # itself daemonizes; we just need to spawn-and-forget.
    subprocess.Popen(
        [ccr, "start"],
        env=env,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        stdin=subprocess.DEVNULL,
        start_new_session=True,
    )

    # Wait up to ~10s for the daemon to bind its port.
    deadline = time.monotonic() + 10
    while time.monotonic() < deadline:
        if daemon_alive():
            return
        time.sleep(0.2)
    die(
        "daemon failed to start within 10s -- try `ccr start` manually and "
        "check ~/.claude-code-router/claude-code-router.log"
    )


def prime_provider(name: str) -> None:
    status, body = daemon_post("/__admin/prime", {"provider": name}, timeout=30)
    if status >= 400:
        # The daemon emits structured errors; just relay the message.
        try:
            msg = json.loads(body).get("error", {}).get("message", body)
        except json.JSONDecodeError:
            msg = body
        die(f"prime failed for '{name}': {msg}")


def lookup_model(name: str) -> str:
    status, body = daemon_get(f"/__admin/model?provider={urllib.parse.quote(name)}")
    if status >= 400:
        try:
            msg = json.loads(body).get("error", {}).get("message", body)
        except json.JSONDecodeError:
            msg = body
        die(f"model lookup failed for '{name}': {msg}")
    return body.strip()


def cmd_list() -> None:
    """Pretty-print the configured providers. Falls back to a direct config
    read if the daemon isn't reachable -- handy for diagnosing setup."""
    if daemon_alive():
        status, body = daemon_get("/__admin/providers")
        if status >= 400:
            die(f"daemon refused /__admin/providers: HTTP {status}")
        data = json.loads(body)
        rows = data.get("providers", [])
    else:
        try:
            cfg = json.loads(ICODE_CFG.read_text())
        except (OSError, json.JSONDecodeError) as e:
            die(f"{ICODE_CFG}: {e}")
        rows = [
            {"name": p["name"], "type": p.get("type", "openai"), "model": p["model"]}
            for p in cfg.get("providers", [])
        ]
    if not rows:
        return
    width = max(len(r["name"]) for r in rows)
    for r in rows:
        print(f"{r['name']:<{width}}  {r['type']:<9}  {r['model']}")


# ---- main -----------------------------------------------------------------


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="icode",
        description=(
            "Run claude-code through the local code-router daemon, "
            "routing this session to a chosen provider."
        ),
        add_help=False,
    )
    parser.add_argument("--provider", metavar="NAME")
    parser.add_argument("--list", action="store_true")
    parser.add_argument("--safe", action="store_true")
    # Everything else is forwarded to claude-code.
    args, forward = parser.parse_known_args()

    if args.list:
        cmd_list()
        return

    ensure_daemon_running()

    provider = args.provider or read_default_provider()
    if not provider:
        die(
            "no default configured and no provider specified\n"
            f"  set {DEFAULT_FILE} (provider = \"NAME\") or pass --provider NAME",
            code=2,
        )

    prime_provider(provider)
    model = lookup_model(provider)

    # Env that points claude-code at the local daemon. Mirrors what `ccr code`
    # would have done, but we exec claude directly to avoid the
    # isServiceRunning() check, which looks at the calling user's pid file
    # (wrong location in system mode, fragile in per-user mode).
    os.environ["ANTHROPIC_BASE_URL"] = DAEMON_BASE
    os.environ["ANTHROPIC_AUTH_TOKEN"] = "test"  # daemon ignores; auth is in-daemon
    os.environ["NO_PROXY"] = "127.0.0.1"
    os.environ["DISABLE_TELEMETRY"] = "true"
    os.environ["DISABLE_COST_WARNINGS"] = "true"
    os.environ.setdefault("API_TIMEOUT_MS", "600000")
    # Bump Read tool's per-call cap from 25k to 128k so large MCP results
    # (e.g. multi-sheet xlsx dumps) don't blow up ingestion.
    os.environ.setdefault("CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS", "128000")
    os.environ.pop("CLAUDE_CODE_USE_BEDROCK", None)

    skip_perms = []
    if not args.safe and os.geteuid() != 0:
        # claude-code refuses --dangerously-skip-permissions when running as
        # root or under sudo.
        skip_perms = ["--dangerously-skip-permissions"]

    claude = shutil.which("claude")
    if not claude:
        die("claude not on PATH (is @anthropic-ai/claude-code installed?)")

    argv = [claude, "--model", f"{provider},{model}", *skip_perms, *forward]
    os.execvp(claude, argv)


if __name__ == "__main__":
    main()
