#!/usr/bin/env python3
"""code-router-refresh-token -- maintain per-provider OAuth tokens for the
"warm" set of icode providers.

Layout (paths env-driven; defaults shown):
  ICODE_CFG               $HOME/.config/icode/config.json   provider list (source of truth)
  ICODE_CFG_DIR/default.toml                                names the default provider,
                                                              format: provider = "name"
  CCR_DIR                 $HOME/.claude-code-router/        CCR daemon state
    config.json                                             CCR daemon config (Providers[],Router)
    tokens/<n>.txt                                          per-provider OAuth bearer token
    used/<n>                                                zero-byte marker; mtime = last use

Modes:
  no args                  refresh every "warm" provider, GC stale ones.
                           warm = {default} ∪ {p : used/p mtime within IDLE_TTL_SEC}
  --provider NAME          prime: mint NAME's token, touch used/NAME. Does not
                           mutate any other provider's token or any default.
                           Called by icode at session launch.
  --print-model NAME       print the configured model for NAME (used by icode)
  --list                   list configured providers

The single CCR daemon serves multiple providers concurrently via per-request
"provider,model" routing. inject-token.js and the patched Anthropic transformer
each read tokens/<provider.name>.txt per request and touch used/<provider.name>
so the timer keeps the active set warm without operator action.
"""

import argparse
import base64
import json
import os
import pwd
import re
import ssl
import sys
import tempfile
import time
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path

# Self-configure for system mode. When invoked as user `code-router` (the
# systemd unit or icode-in-system-mode via NOPASSWD sudo), default paths to
# the system install locations rather than $HOME-relative ones. Explicit env
# vars still win. Per-user invocations are unaffected.
try:
    if pwd.getpwuid(os.geteuid()).pw_name == "code-router":
        _SYS_BASE = "/var/lib/code-router"
        os.environ.setdefault("ICODE_CFG", "/etc/icode/config.json")
        os.environ.setdefault("CODE_ROUTER_DIR", f"{_SYS_BASE}/.claude-code-router")
        os.environ.setdefault("CODE_ROUTER_PLUGIN_DIR", "/usr/local/share/code-router/plugins")
        os.environ.setdefault("CODE_ROUTER_CA_FILE", "/usr/local/share/code-router/ca.pem")
except KeyError:
    pass

HOME = Path.home()
ICODE_CFG = Path(os.environ.get("ICODE_CFG", HOME / ".config" / "icode" / "config.json"))
ICODE_CFG_DIR = ICODE_CFG.parent
DEFAULT_FILE = ICODE_CFG_DIR / "default.toml"

CCR_DIR = Path(os.environ.get("CODE_ROUTER_DIR", HOME / ".claude-code-router"))
CCR_CFG = CCR_DIR / "config.json"
TOKENS_DIR = CCR_DIR / "tokens"
USED_DIR = CCR_DIR / "used"
LEGACY_TOKEN_FILE = CCR_DIR / "token.txt"
LEGACY_ACTIVE_FILE = CCR_DIR / "active-provider"

CA_FILE = Path(os.environ.get(
    "CODE_ROUTER_CA_FILE",
    HOME / ".local" / "share" / "ca-certs" / "code-router-ca.pem",
))
PLUGIN_DIR = Path(os.environ.get("CODE_ROUTER_PLUGIN_DIR", CCR_DIR / "plugins"))

SUPPORTED_TYPES = ("openai", "anthropic")
IDLE_TTL_SEC = 2 * 3600  # warm window: 2h since last use

# Single line: provider = "name". Anything beyond that is ignored so the file
# stays trivially editable by hand.
# Canonical TOML is `provider = "NAME"`, but be lenient with hand-edited
# files: accept bare (`provider = name`) and single-quoted forms too. Outer
# matching quote is stripped after capture.
DEFAULT_RE = re.compile(
    r'^\s*provider\s*=\s*(.+?)\s*(?:#.*)?$', re.MULTILINE
)


def _strip_quotes(s: str) -> str:
    if len(s) >= 2 and s[0] == s[-1] and s[0] in ('"', "'"):
        return s[1:-1]
    return s


class MintError(Exception):
    """Raised by mint_token on any non-recoverable mint failure. Callers
    decide whether to die (prime mode) or continue (warm-set refresh)."""


def die(msg, code=1):
    print(f"code-router-refresh-token: {msg}", file=sys.stderr)
    sys.exit(code)


def atomic_write(path: Path, content: str, mode: int = 0o600) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp = tempfile.mkstemp(prefix=f".{path.name}.", dir=str(path.parent))
    try:
        with os.fdopen(fd, "w") as f:
            f.write(content)
        os.chmod(tmp, mode)
        os.replace(tmp, path)
    except Exception:
        try:
            os.unlink(tmp)
        except FileNotFoundError:
            pass
        raise


def load_config() -> list:
    if not ICODE_CFG.is_file():
        die(
            f"{ICODE_CFG} not readable\n"
            "  create it with one or more 'providers' entries; see README for schema"
        )
    try:
        with open(ICODE_CFG) as f:
            cfg = json.load(f)
    except json.JSONDecodeError as e:
        die(f"{ICODE_CFG}: invalid JSON: {e}")
    providers = cfg.get("providers")
    if not isinstance(providers, list) or not providers:
        die(f"{ICODE_CFG} must define a non-empty 'providers' array")
    seen = set()
    for p in providers:
        if not isinstance(p, dict) or not p.get("name"):
            die(f"{ICODE_CFG}: each provider entry must be an object with a 'name'")
        if p["name"] in seen:
            die(f"{ICODE_CFG}: duplicate provider name '{p['name']}'")
        seen.add(p["name"])
        t = p.get("type", "openai")
        if t not in SUPPORTED_TYPES:
            die(
                f"{ICODE_CFG}: provider '{p['name']}' has unknown type '{t}' "
                f"(supported: {', '.join(SUPPORTED_TYPES)})"
            )
    return providers


def read_default(names: set) -> str | None:
    """Return the default provider name from default.toml, or None if no
    default file exists. Validates membership against the current config."""
    if not DEFAULT_FILE.is_file():
        return None
    try:
        text = DEFAULT_FILE.read_text()
    except OSError as e:
        die(f"{DEFAULT_FILE}: {e}")
    m = DEFAULT_RE.search(text)
    if not m:
        die(f"{DEFAULT_FILE}: expected a line `provider = \"NAME\"`")
    name = _strip_quotes(m.group(1).strip())
    if name not in names:
        die(
            f"{DEFAULT_FILE}: default provider '{name}' is not in {ICODE_CFG}\n"
            f"  available: {' '.join(sorted(names))}"
        )
    return name


def required_fields(p_type: str) -> set:
    base = {"client_id", "client_secret", "token_url", "base_url", "model"}
    if p_type == "openai":
        return base | {"deployment_name", "api_version"}
    return base


def mint_token(p: dict) -> tuple[str, object]:
    """OAuth client_credentials mint. Raises MintError on failure (callers
    decide whether to die or continue past it)."""
    body = urllib.parse.urlencode(
        {"grant_type": "client_credentials", "scope": p.get("token_scope", "")}
    ).encode()
    creds = f"{p['client_id']}:{p['client_secret']}".encode()
    headers = {
        "Authorization": "Basic " + base64.b64encode(creds).decode(),
        "Content-Type": "application/x-www-form-urlencoded",
    }
    req = urllib.request.Request(p["token_url"], data=body, headers=headers, method="POST")

    # System CAs PLUS the corporate bundle. cafile= would replace system CAs;
    # load_verify_locations adds to them.
    ctx = ssl.create_default_context()
    if CA_FILE.is_file():
        ctx.load_verify_locations(cafile=str(CA_FILE))

    try:
        with urllib.request.urlopen(req, context=ctx, timeout=30) as resp:
            payload = json.loads(resp.read())
    except urllib.error.HTTPError as e:
        body = e.read().decode(errors="replace")
        raise MintError(f"HTTP {e.code}\n{body}")
    except urllib.error.URLError as e:
        raise MintError(str(e.reason))

    token = payload.get("access_token") if isinstance(payload, dict) else None
    if not token:
        raise MintError(f"unexpected response:\n{json.dumps(payload, indent=2)}")
    return token, payload.get("expires_in", "?")


def build_ccr_provider(p: dict) -> dict:
    p_type = p.get("type", "openai")
    if p_type == "openai":
        url = (
            p["base_url"]
            + "/openai/deployments/"
            + p["deployment_name"]
            + "/chat/completions?api-version="
            + p["api_version"]
        )
        return {
            "name": p["name"],
            "api_base_url": url,
            "api_key": "PLACEHOLDER_OVERRIDDEN_BY_INJECT_TOKEN",
            "models": [p["model"]],
            "transformer": {
                "use": ["openai", "strip-reasoning", "maxcompletiontokens", "inject-token"]
            },
        }
    return {
        "name": p["name"],
        "api_base_url": p["base_url"] + "/v1/messages",
        "api_key": "PLACEHOLDER_OVERRIDDEN_BY_TOKEN_DIR",
        "models": [p["model"]],
        "transformer": {"use": ["Anthropic"]},
    }


def update_ccr_config(providers: list, default_name: str | None) -> bool:
    """Rebuild Providers[] and Router.default. Returns True if a fresh bootstrap
    was written (vs an in-place update of an existing config)."""
    new_providers = [build_ccr_provider(p) for p in providers]
    # Router.default is a fallback for requests that arrive without a model
    # arg. icode always passes --model, so this is mostly defensive. If no
    # default.toml exists, fall back to the first configured provider.
    d_name = default_name if default_name else providers[0]["name"]
    d = next(p for p in providers if p["name"] == d_name)
    router_default = f"{d['name']},{d['model']}"

    plugin_strip = str(PLUGIN_DIR / "strip-reasoning.js")
    plugin_inject = str(PLUGIN_DIR / "inject-token.js")

    existing = None
    if CCR_CFG.is_file():
        try:
            with open(CCR_CFG) as f:
                existing = json.load(f)
        except json.JSONDecodeError:
            existing = None

    need_bootstrap = existing is None or "inject-token" not in json.dumps(
        existing.get("transformers", [])
    )
    if need_bootstrap:
        cfg = {
            "LOG": False,
            "API_TIMEOUT_MS": 600000,
            "transformers": [
                {"path": plugin_strip},
                {"path": plugin_inject},
            ],
            "Providers": new_providers,
            "Router": {"default": router_default},
        }
    else:
        cfg = existing
        cfg["Providers"] = new_providers
        cfg.setdefault("Router", {})["default"] = router_default

    atomic_write(CCR_CFG, json.dumps(cfg, indent=2) + "\n", mode=0o600)
    return need_bootstrap


def touch_used(name: str) -> None:
    """Create the per-provider marker if missing, then bump its mtime to now.
    Plugin code also touches this on each request; we touch it here so the
    very next timer tick sees the provider as warm."""
    USED_DIR.mkdir(parents=True, exist_ok=True)
    p = USED_DIR / name
    if not p.exists():
        with open(p, "a"):
            pass
        os.chmod(p, 0o600)
    os.utime(p, None)


def write_token(name: str, token: str) -> None:
    TOKENS_DIR.mkdir(parents=True, exist_ok=True)
    atomic_write(TOKENS_DIR / f"{name}.txt", token + "\n", mode=0o600)


def maybe_migrate() -> None:
    """One-shot migration from the legacy single-token layout. After this runs
    once, the legacy files are gone and subsequent invocations are no-ops."""
    if TOKENS_DIR.exists() or not LEGACY_TOKEN_FILE.is_file():
        return
    active = None
    if LEGACY_ACTIVE_FILE.is_file():
        try:
            active = LEGACY_ACTIVE_FILE.read_text().strip() or None
        except OSError:
            active = None
    if active:
        try:
            content = LEGACY_TOKEN_FILE.read_text()
        except OSError:
            content = None
        if content:
            TOKENS_DIR.mkdir(parents=True, exist_ok=True)
            atomic_write(TOKENS_DIR / f"{active}.txt", content, mode=0o600)
            touch_used(active)
            print(
                f"code-router: migrated legacy token -> tokens/{active}.txt",
                file=sys.stderr,
            )
    # Clean up legacy files regardless: if we couldn't preserve, the next
    # prime call will mint fresh.
    for f in (LEGACY_TOKEN_FILE, LEGACY_ACTIVE_FILE):
        try:
            f.unlink()
        except FileNotFoundError:
            pass


def cmd_list(providers: list) -> None:
    width = max(len(p["name"]) for p in providers)
    for p in providers:
        print(f"{p['name']:<{width}}  {p.get('type', 'openai')}")


def cmd_print_model(providers: list, name: str) -> None:
    for p in providers:
        if p["name"] == name:
            print(p["model"])
            return
    die(f"provider '{name}' not found in {ICODE_CFG}", code=2)


def cmd_prime(providers: list, name: str) -> None:
    p = next((x for x in providers if x["name"] == name), None)
    if p is None:
        die(f"provider '{name}' not found in {ICODE_CFG}")
    p_type = p.get("type", "openai")
    missing = sorted(k for k in required_fields(p_type) if not p.get(k))
    if missing:
        die(
            f"provider '{name}' (type={p_type}) is missing required field(s): "
            + ", ".join(missing)
        )
    try:
        token, expires_in = mint_token(p)
    except MintError as e:
        die(f"token mint failed for provider '{name}': {e}")
    write_token(name, token)
    touch_used(name)
    # Keep Providers[] in sync in case config changed since the daemon started.
    update_ccr_config(providers, read_default({q["name"] for q in providers}))
    print(
        f"code-router: token primed for '{name}' "
        f"(type: {p_type}, expires in {expires_in}s)"
    )


def cmd_refresh(providers: list, default_name: str | None) -> None:
    """Timer-driven: refresh the warm set, GC the rest."""
    names = {p["name"] for p in providers}
    now = time.time()
    warm = set()
    if default_name and default_name in names:
        warm.add(default_name)
    if USED_DIR.is_dir():
        for marker in USED_DIR.iterdir():
            if marker.name in names:
                try:
                    if now - marker.stat().st_mtime < IDLE_TTL_SEC:
                        warm.add(marker.name)
                except FileNotFoundError:
                    pass

    refreshed, errors = [], []
    for name in sorted(warm):
        p = next(x for x in providers if x["name"] == name)
        miss = sorted(k for k in required_fields(p.get("type", "openai")) if not p.get(k))
        if miss:
            errors.append((name, "missing fields: " + ", ".join(miss)))
            continue
        try:
            token, _ = mint_token(p)
        except MintError as e:
            errors.append((name, f"mint failed: {e}"))
            continue
        write_token(name, token)
        refreshed.append(name)

    # GC: anything in tokens/ or used/ outside the warm set, including names
    # that are no longer in the icode config.
    if TOKENS_DIR.is_dir():
        for f in TOKENS_DIR.iterdir():
            if f.suffix == ".txt" and f.stem not in warm:
                try:
                    f.unlink()
                except FileNotFoundError:
                    pass
    if USED_DIR.is_dir():
        for f in USED_DIR.iterdir():
            if f.name not in warm:
                try:
                    f.unlink()
                except FileNotFoundError:
                    pass

    update_ccr_config(providers, default_name)

    if refreshed:
        print(f"code-router: refreshed [{' '.join(refreshed)}]")
    elif not warm:
        print("code-router: no warm providers; nothing to refresh")
    for name, reason in errors:
        print(f"code-router: refresh skipped '{name}': {reason}", file=sys.stderr)


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="code-router-refresh-token",
        description="Mint per-provider OAuth tokens for icode; maintain CCR config.",
    )
    g = parser.add_mutually_exclusive_group()
    g.add_argument("--provider", metavar="NAME", help="prime NAME's token and exit")
    g.add_argument(
        "--print-model",
        metavar="NAME",
        dest="print_model",
        help="print NAME's configured model and exit",
    )
    g.add_argument("--list", action="store_true", help="list configured providers")
    args = parser.parse_args()

    providers = load_config()
    if args.list:
        cmd_list(providers)
        return
    if args.print_model:
        cmd_print_model(providers, args.print_model)
        return

    maybe_migrate()

    if args.provider:
        cmd_prime(providers, args.provider)
        return

    cmd_refresh(providers, read_default({p["name"] for p in providers}))


if __name__ == "__main__":
    main()
