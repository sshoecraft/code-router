#!/usr/bin/env bash
# code-router-refresh-token -- mint a fresh OAuth bearer token for the
# active provider and atomically write it to ~/.claude-code-router/token.txt.
#
# Two provider flavors are supported:
#
#   type = "openai"     OpenAI-compatible chat-completions gateway. Routed
#                       through CCR; the inject-token plugin reads token.txt
#                       per request and rewrites the Authorization header.
#
#   type = "anthropic"  Anthropic-native Messages API gateway. icode bypasses
#                       CCR for this flavor and execs `claude` directly with
#                       ANTHROPIC_BASE_URL + ANTHROPIC_AUTH_TOKEN exported.
#
# Either way, this script writes the active provider's bearer token to
# ~/.claude-code-router/token.txt. The active provider's name lives in
# ~/.claude-code-router/active-provider so the timer-driven no-arg refresh
# preserves the user's --provider choice.
#
# Usage:
#   code-router-refresh-token                  # refresh active provider
#   code-router-refresh-token --provider NAME  # switch active provider + refresh
#   code-router-refresh-token --list           # list configured providers
#
# Active provider selection (in priority order):
#   1. --provider NAME flag
#   2. ~/.claude-code-router/active-provider file
#   3. name parsed from Router.default in CCR config (legacy fallback)
#   4. first provider in the icode config
#
# Source-of-truth credentials live in ~/.config/icode/config.toml. Override
# with ICODE_CFG=/path/to/config.toml in the environment.

set -euo pipefail

ICODE_CFG="${ICODE_CFG:-$HOME/.config/icode/config.toml}"
CCR_DIR="$HOME/.claude-code-router"
CCR_CFG="$CCR_DIR/config.json"
TOKEN_FILE="$CCR_DIR/token.txt"
ACTIVE_FILE="$CCR_DIR/active-provider"
CA_FILE="$HOME/.local/share/ca-certs/code-router-ca.pem"
PLUGIN_DIR="$CCR_DIR/plugins"

command -v yq >/dev/null || {
  echo "code-router-refresh-token: yq required (https://github.com/mikefarah/yq)" >&2
  exit 1
}

usage() {
  sed -n '/^# Usage:/,/^$/p' "$0" | sed 's/^# \{0,1\}//' >&2
  exit "${1:-2}"
}

REQUESTED_PROVIDER=""
LIST_ONLY=0
while (( $# )); do
  case "$1" in
    --provider) REQUESTED_PROVIDER="${2:-}"; shift 2 ;;
    --provider=*) REQUESTED_PROVIDER="${1#*=}"; shift ;;
    --list) LIST_ONLY=1; shift ;;
    -h|--help) usage 0 ;;
    *) echo "code-router-refresh-token: unknown arg: $1" >&2; usage ;;
  esac
done

if [[ ! -r "$ICODE_CFG" ]]; then
  echo "code-router-refresh-token: $ICODE_CFG not readable" >&2
  echo "  create it with one or more [[providers]] entries; see README for schema" >&2
  exit 1
fi

# Convert TOML to JSON once; downstream jq pipelines reuse this string.
CFG_JSON="$(yq -p toml -o json "$ICODE_CFG")"

if ! jq -e '.providers | length > 0 and all(.name != null and .name != "")' <<<"$CFG_JSON" >/dev/null; then
  echo "code-router-refresh-token: $ICODE_CFG must define [[providers]] entries each with a 'name'" >&2
  exit 1
fi

# Validate each provider's type is one of the supported flavors.
if ! jq -e '.providers | all(((.type // "openai") == "openai") or ((.type // "openai") == "anthropic"))' <<<"$CFG_JSON" >/dev/null; then
  bad="$(jq -r '.providers[] | select(((.type // "openai") != "openai") and ((.type // "openai") != "anthropic")) | "\(.name)=\(.type)"' <<<"$CFG_JSON")"
  echo "code-router-refresh-token: unknown provider type(s): $bad" >&2
  echo "  supported: openai (default), anthropic" >&2
  exit 1
fi

mapfile -t PROVIDER_NAMES < <(jq -r '.providers[].name' <<<"$CFG_JSON")

if (( LIST_ONLY )); then
  jq -r '.providers[] | "\(.name)\t\(.type // "openai")"' <<<"$CFG_JSON" | column -t
  exit 0
fi

# --- Resolve the active provider ---
active_from_file() {
  [[ -r "$ACTIVE_FILE" ]] || return 1
  tr -d '[:space:]' <"$ACTIVE_FILE"
}

active_from_router_default() {
  [[ -r "$CCR_CFG" ]] || return 1
  jq -r '.Router.default // ""' "$CCR_CFG" 2>/dev/null | awk -F, 'NF>0 && $1!="" {print $1; exit}'
}

ACTIVE=""
if [[ -n "$REQUESTED_PROVIDER" ]]; then
  ACTIVE="$REQUESTED_PROVIDER"
elif a="$(active_from_file)" && [[ -n "$a" ]]; then
  ACTIVE="$a"
elif a="$(active_from_router_default)" && [[ -n "$a" ]]; then
  ACTIVE="$a"
else
  ACTIVE="${PROVIDER_NAMES[0]}"
fi

if ! printf '%s\n' "${PROVIDER_NAMES[@]}" | grep -Fxq "$ACTIVE"; then
  echo "code-router-refresh-token: provider '$ACTIVE' not found in $ICODE_CFG" >&2
  echo "  available: ${PROVIDER_NAMES[*]}" >&2
  exit 1
fi

# --- Read fields for the active provider ---
read_field() {
  jq -r --arg name "$ACTIVE" --arg f "$1" \
    '.providers[] | select(.name == $name) | .[$f] // ""' <<<"$CFG_JSON"
}

TYPE="$(read_field type)"
[[ -n "$TYPE" ]] || TYPE="openai"

CLIENT_ID="$(read_field client_id)"
CLIENT_SECRET="$(read_field client_secret)"
TOKEN_URL="$(read_field token_url)"
TOKEN_SCOPE="$(read_field token_scope)"
BASE_URL="$(read_field base_url)"
DEPLOYMENT="$(read_field deployment_name)"
API_VERSION="$(read_field api_version)"
MODEL="$(read_field model)"

required_for_type() {
  case "$1" in
    openai)    echo "CLIENT_ID CLIENT_SECRET TOKEN_URL BASE_URL DEPLOYMENT API_VERSION MODEL" ;;
    anthropic) echo "CLIENT_ID CLIENT_SECRET TOKEN_URL BASE_URL MODEL" ;;
  esac
}
for var in $(required_for_type "$TYPE"); do
  if [[ -z "${!var}" ]]; then
    echo "code-router-refresh-token: provider '$ACTIVE' (type=$TYPE) is missing required field: $var" >&2
    exit 1
  fi
done

# --- Mint a fresh OAuth bearer token for the active provider ---
CURL_OPTS=(-sSf -X POST "$TOKEN_URL"
  -u "$CLIENT_ID:$CLIENT_SECRET"
  -d "grant_type=client_credentials&scope=$TOKEN_SCOPE")
if [[ -r "$CA_FILE" ]]; then
  CURL_OPTS+=(--cacert "$CA_FILE")
else
  CURL_OPTS+=(-k)
fi

TOKEN_JSON="$(curl "${CURL_OPTS[@]}")"
ACCESS_TOKEN="$(jq -r '.access_token' <<<"$TOKEN_JSON")"
EXPIRES_IN="$(jq -r '.expires_in // "?"' <<<"$TOKEN_JSON")"
if [[ -z "$ACCESS_TOKEN" || "$ACCESS_TOKEN" == "null" ]]; then
  echo "code-router-refresh-token: token mint failed for provider '$ACTIVE'" >&2
  jq . <<<"$TOKEN_JSON" >&2
  exit 1
fi

# --- Atomically publish the token + active-provider name ---
mkdir -p "$CCR_DIR"
umask 077
TMP="$(mktemp "$CCR_DIR/.token.XXXXXX")"
printf '%s\n' "$ACCESS_TOKEN" >"$TMP"
chmod 600 "$TMP"
mv -f "$TMP" "$TOKEN_FILE"

TMP="$(mktemp "$CCR_DIR/.active.XXXXXX")"
printf '%s\n' "$ACTIVE" >"$TMP"
chmod 600 "$TMP"
mv -f "$TMP" "$ACTIVE_FILE"

# --- Build CCR's Providers[] from ALL configured providers.
#     openai providers use the openai chain + inject-token for auth.
#     anthropic providers use the (patched) "Anthropic" passthrough; the
#     CCR daemon reads ANTHROPIC_TOKEN_FILE on each request.
PROVIDERS_JSON="$(jq \
  '[ .providers[] | (.type // "openai") as $t |
     if $t == "openai" then {
       name: .name,
       api_base_url: ((.base_url) + "/openai/deployments/" + .deployment_name +
                      "/chat/completions?api-version=" + .api_version),
       api_key: "PLACEHOLDER_OVERRIDDEN_BY_INJECT_TOKEN",
       models: [.model],
       transformer: { use: ["openai", "strip-reasoning", "maxcompletiontokens", "inject-token"] }
     } elif $t == "anthropic" then {
       name: .name,
       api_base_url: ((.base_url) + "/v1/messages"),
       api_key: "PLACEHOLDER_OVERRIDDEN_BY_TOKEN_FILE",
       models: [.model],
       transformer: { use: ["Anthropic"] }
     } else empty end
   ]' <<<"$CFG_JSON")"

# Router.default points at the active provider, regardless of type.
ROUTER_DEFAULT="$(jq -r --arg n "$ACTIVE" '.providers[] | select(.name == $n) | (.name + "," + .model)' <<<"$CFG_JSON")"

PLUGIN_STRIP="$PLUGIN_DIR/strip-reasoning.js"
PLUGIN_INJECT="$PLUGIN_DIR/inject-token.js"

need_bootstrap=0
if [[ ! -r "$CCR_CFG" ]]; then
  need_bootstrap=1
elif ! grep -q "inject-token" "$CCR_CFG" 2>/dev/null; then
  need_bootstrap=1
fi

if (( need_bootstrap )); then
  jq -n \
    --argjson providers "$PROVIDERS_JSON" \
    --arg router_default "$ROUTER_DEFAULT" \
    --arg plugin_strip "$PLUGIN_STRIP" \
    --arg plugin_inject "$PLUGIN_INJECT" \
    '{
      LOG: false,
      API_TIMEOUT_MS: 600000,
      transformers: [
        { path: $plugin_strip },
        { path: $plugin_inject }
      ],
      Providers: $providers,
      Router: { default: $router_default }
    }' >"$CCR_CFG"
  chmod 600 "$CCR_CFG"
  echo "code-router: wrote config -> $CCR_CFG (active: $ACTIVE, type: $TYPE)"
else
  # In-place update: refresh Providers[] always; refresh Router.default
  # only when the user explicitly switched providers this run.
  TMP_CFG="$(mktemp "$CCR_DIR/.config.XXXXXX")"
  if [[ -n "$REQUESTED_PROVIDER" ]]; then
    jq --argjson providers "$PROVIDERS_JSON" \
       --arg router_default "$ROUTER_DEFAULT" \
       '.Providers = $providers | .Router.default = $router_default' \
       "$CCR_CFG" >"$TMP_CFG"
  else
    jq --argjson providers "$PROVIDERS_JSON" \
       '.Providers = $providers' \
       "$CCR_CFG" >"$TMP_CFG"
  fi
  chmod 600 "$TMP_CFG"
  mv -f "$TMP_CFG" "$CCR_CFG"
fi

echo "code-router: token refreshed for '$ACTIVE' (type: $TYPE, expires in ${EXPIRES_IN}s)"
