#!/usr/bin/env python3
"""code-router-refresh-token -- mint a fresh OAuth bearer token for the
active provider and atomically write it to ~/.claude-code-router/token.txt.

Two provider flavors are supported:

  type = "openai"     OpenAI-compatible chat-completions gateway. Routed
                      through CCR; the inject-token plugin reads token.txt
                      per request and rewrites the Authorization header.

  type = "anthropic"  Anthropic-native Messages API gateway. Routed through
                      CCR using the patched Anthropic transformer, which
                      reads token.txt per request (gated on
                      ANTHROPIC_TOKEN_FILE) and strips/clamps body fields
                      the gateway's older API rejects.

Either way, this script writes the active provider's bearer token to
~/.claude-code-router/token.txt. The active provider's name lives in
~/.claude-code-router/active-provider so the timer-driven no-arg refresh
preserves the user's --provider choice.

Usage:
  code-router-refresh-token                  refresh active provider
  code-router-refresh-token --provider NAME  switch active provider + refresh
  code-router-refresh-token --list           list configured providers

Active provider selection (in priority order):
  1. --provider NAME flag
  2. ~/.claude-code-router/active-provider file
  3. name parsed from Router.default in the existing CCR config
  4. first provider in the icode config

Source-of-truth credentials live in ~/.config/icode/config.json. Override
with ICODE_CFG=/path/to/config.json in the environment. The schema is:

  {
    "providers": [
      {
        "name":            "azprod",
        "type":            "openai",         // or "anthropic"; default "openai"
        "client_id":       "...",
        "client_secret":   "...",
        "token_url":       "https://.../oauth2/.../v1/token",
        "token_scope":     "...",
        "base_url":        "https://gateway.example.com/...",
        "deployment_name": "...",            // openai only
        "api_version":     "2024-06-01",     // openai only
        "model":           "..."
      }
    ]
  }

This script is pure-stdlib Python 3; no external packages required.
"""

import argparse
import base64
import json
import os
import ssl
import sys
import tempfile
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path

# Paths are env-var-driven so the same script serves both per-user installs
# (defaults below) and system installs (the systemd unit sets the env vars
# to point at /etc/icode, /var/lib/code-router, /usr/local/share/...).
HOME = Path.home()
ICODE_CFG = Path(os.environ.get("ICODE_CFG", HOME / ".config" / "icode" / "config.json"))
CCR_DIR = Path(os.environ.get("CODE_ROUTER_DIR", HOME / ".claude-code-router"))
CCR_CFG = CCR_DIR / "config.json"
TOKEN_FILE = CCR_DIR / "token.txt"
ACTIVE_FILE = CCR_DIR / "active-provider"
CA_FILE = Path(os.environ.get(
    "CODE_ROUTER_CA_FILE",
    HOME / ".local" / "share" / "ca-certs" / "code-router-ca.pem",
))
PLUGIN_DIR = Path(os.environ.get("CODE_ROUTER_PLUGIN_DIR", CCR_DIR / "plugins"))
SUPPORTED_TYPES = ("openai", "anthropic")


def die(msg, code=1):
    print(f"code-router-refresh-token: {msg}", file=sys.stderr)
    sys.exit(code)


def atomic_write(path: Path, content: str, mode: int = 0o600) -> None:
    """Write content to path via tempfile + rename so readers never see a
    half-written file."""
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp = tempfile.mkstemp(prefix=f".{path.name}.", dir=str(path.parent))
    try:
        with os.fdopen(fd, "w") as f:
            f.write(content)
        os.chmod(tmp, mode)
        os.replace(tmp, path)
    except Exception:
        try:
            os.unlink(tmp)
        except FileNotFoundError:
            pass
        raise


def load_config() -> list:
    if not ICODE_CFG.is_file():
        die(
            f"{ICODE_CFG} not readable\n"
            "  create it with one or more 'providers' entries; see README for schema"
        )
    try:
        with open(ICODE_CFG) as f:
            cfg = json.load(f)
    except json.JSONDecodeError as e:
        die(f"{ICODE_CFG}: invalid JSON: {e}")

    providers = cfg.get("providers")
    if not isinstance(providers, list) or not providers:
        die(f"{ICODE_CFG} must define a non-empty 'providers' array")

    for p in providers:
        if not isinstance(p, dict) or not p.get("name"):
            die(f"{ICODE_CFG}: each provider entry must be an object with a 'name'")
        t = p.get("type", "openai")
        if t not in SUPPORTED_TYPES:
            die(
                f"{ICODE_CFG}: provider '{p['name']}' has unknown type '{t}' "
                f"(supported: {', '.join(SUPPORTED_TYPES)})"
            )
    return providers


def resolve_active(providers: list, requested: str | None) -> str:
    names = [p["name"] for p in providers]
    if requested:
        active = requested
    else:
        active = ""
        try:
            active = ACTIVE_FILE.read_text().strip()
        except FileNotFoundError:
            pass
        if not active and CCR_CFG.is_file():
            try:
                with open(CCR_CFG) as f:
                    rd = (json.load(f).get("Router") or {}).get("default", "")
                active = rd.split(",", 1)[0] if rd else ""
            except json.JSONDecodeError:
                pass
        if not active:
            active = names[0]

    if active not in names:
        die(
            f"provider '{active}' not found in {ICODE_CFG}\n"
            f"  available: {' '.join(names)}"
        )
    return active


def required_fields(p_type: str) -> set:
    base = {"client_id", "client_secret", "token_url", "base_url", "model"}
    if p_type == "openai":
        return base | {"deployment_name", "api_version"}
    return base


def mint_token(p: dict) -> tuple[str, object]:
    """Mint a fresh OAuth client_credentials bearer token. Mirrors
    `curl -u id:secret -d grant_type=...&scope=...` with the corporate CA
    bundle when available."""
    body = urllib.parse.urlencode(
        {"grant_type": "client_credentials", "scope": p.get("token_scope", "")}
    ).encode()

    creds = f"{p['client_id']}:{p['client_secret']}".encode()
    headers = {
        "Authorization": "Basic " + base64.b64encode(creds).decode(),
        "Content-Type": "application/x-www-form-urlencoded",
    }
    req = urllib.request.Request(p["token_url"], data=body, headers=headers, method="POST")

    # Use system CAs (Okta and other public TLDs) and ALSO trust the
    # corporate bundle (gateway hosts behind the McKesson root CA). This
    # mirrors curl's `--cacert FILE`, which keeps the system CApath
    # alongside the supplied file, while Python's `cafile=` argument would
    # replace system CAs entirely.
    ctx = ssl.create_default_context()
    if CA_FILE.is_file():
        ctx.load_verify_locations(cafile=str(CA_FILE))

    try:
        with urllib.request.urlopen(req, context=ctx, timeout=30) as resp:
            payload = json.loads(resp.read())
    except urllib.error.HTTPError as e:
        body = e.read().decode(errors="replace")
        die(f"token mint failed for provider '{p['name']}': HTTP {e.code}\n{body}")
    except urllib.error.URLError as e:
        die(f"token mint failed for provider '{p['name']}': {e.reason}")

    token = payload.get("access_token") if isinstance(payload, dict) else None
    if not token:
        die(
            f"token mint failed for provider '{p['name']}':\n"
            f"{json.dumps(payload, indent=2)}"
        )
    return token, payload.get("expires_in", "?")


def build_ccr_provider(p: dict) -> dict:
    """Build a CCR Providers[] entry for one icode provider."""
    p_type = p.get("type", "openai")
    if p_type == "openai":
        url = (
            p["base_url"]
            + "/openai/deployments/"
            + p["deployment_name"]
            + "/chat/completions?api-version="
            + p["api_version"]
        )
        return {
            "name": p["name"],
            "api_base_url": url,
            "api_key": "PLACEHOLDER_OVERRIDDEN_BY_INJECT_TOKEN",
            "models": [p["model"]],
            "transformer": {
                "use": ["openai", "strip-reasoning", "maxcompletiontokens", "inject-token"]
            },
        }
    # anthropic
    return {
        "name": p["name"],
        "api_base_url": p["base_url"] + "/v1/messages",
        "api_key": "PLACEHOLDER_OVERRIDDEN_BY_TOKEN_FILE",
        "models": [p["model"]],
        "transformer": {"use": ["Anthropic"]},
    }


def update_ccr_config(
    providers: list, active: str, active_model: str, requested: str | None
) -> bool:
    """Bootstrap or in-place-update the CCR config. Returns True if a fresh
    bootstrap was written."""
    new_providers = [build_ccr_provider(p) for p in providers]
    router_default = f"{active},{active_model}"

    plugin_strip = str(PLUGIN_DIR / "strip-reasoning.js")
    plugin_inject = str(PLUGIN_DIR / "inject-token.js")

    existing = None
    if CCR_CFG.is_file():
        try:
            with open(CCR_CFG) as f:
                existing = json.load(f)
        except json.JSONDecodeError:
            existing = None

    # Treat missing or stale (no inject-token plugin) configs as needing bootstrap.
    need_bootstrap = existing is None or "inject-token" not in json.dumps(
        existing.get("transformers", [])
    )

    if need_bootstrap:
        cfg = {
            "LOG": False,
            "API_TIMEOUT_MS": 600000,
            "transformers": [
                {"path": plugin_strip},
                {"path": plugin_inject},
            ],
            "Providers": new_providers,
            "Router": {"default": router_default},
        }
    else:
        cfg = existing
        cfg["Providers"] = new_providers
        # Update Router.default only when the user explicitly switched, so
        # the timer-driven no-arg refresh preserves the active selection.
        if requested:
            cfg.setdefault("Router", {})["default"] = router_default

    atomic_write(CCR_CFG, json.dumps(cfg, indent=2) + "\n", mode=0o600)
    return need_bootstrap


def cmd_list(providers: list) -> None:
    width = max(len(p["name"]) for p in providers)
    for p in providers:
        print(f"{p['name']:<{width}}  {p.get('type', 'openai')}")


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="code-router-refresh-token",
        description="Mint OAuth tokens for icode providers; maintain CCR config.",
    )
    parser.add_argument("--provider", help="switch active provider, then refresh")
    parser.add_argument(
        "--list", action="store_true", help="list configured providers and exit"
    )
    args = parser.parse_args()

    providers = load_config()

    if args.list:
        cmd_list(providers)
        return

    active = resolve_active(providers, args.provider)
    p = next(x for x in providers if x["name"] == active)
    p_type = p.get("type", "openai")

    missing = sorted(k for k in required_fields(p_type) if not p.get(k))
    if missing:
        die(
            f"provider '{active}' (type={p_type}) is missing required field(s): "
            + ", ".join(missing)
        )

    token, expires_in = mint_token(p)

    atomic_write(TOKEN_FILE, token + "\n", mode=0o600)
    atomic_write(ACTIVE_FILE, active + "\n", mode=0o600)

    bootstrapped = update_ccr_config(providers, active, p["model"], args.provider)
    if bootstrapped:
        print(f"code-router: wrote config -> {CCR_CFG} (active: {active}, type: {p_type})")
    print(f"code-router: token refreshed for '{active}' (type: {p_type}, expires in {expires_in}s)")


if __name__ == "__main__":
    main()
