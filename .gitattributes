# Force LF line endings for all text files — this repo is Linux/WSL only,
# and the shell scripts, systemd units, and Makefile break if checked out
# with CRLF on Windows.
* text=auto eol=lf

# Binary types (don't touch these)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# Shell scripts and systemd units must be LF regardless of anything else
*.sh           text eol=lf
bin/*          text eol=lf
*.service      text eol=lf
*.timer        text eol=lf
Makefile       text eol=lf
